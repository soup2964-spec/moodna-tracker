# iClosed (same as Bustem) — copy your event URL from AI Scheduler → Events → Embed
# Example: https://app.iclosed.io/e/Moodna/free-brand-protection-strategy-call
VITE_BOOKING_URL=

# Title shown on the inline scheduler widget
VITE_BOOKING_TITLE=Free 15-Min 360° Threat Report

# popup = buttons open scheduler popup | link = open in new tab
# Inline widget always shows on the booking section (#cta)
VITE_BOOKING_MODE=popup

# Clerk auth — https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Supabase app data — https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only (do not prefix with VITE_)
PORT=8787
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
MOODNA_ORG_ID=

# Scheduler — 2 scans per brand per day
SCHEDULER_ENABLED=true
SCHEDULER_SECRET=
SCAN_AM_TIME=09:00
SCAN_PM_TIME=21:00
SCAN_TIMEZONE=UTC

# PublicWWW — HTML/CSS/JS source code search (https://publicwww.com)
PUBLICWWW_API_KEY=

# Serper — Google search API for marketplace listings (https://serper.dev)
SERPER_API_KEY=

# Optional richer website crawl — https://firecrawl.dev
FIRECRAWL_API_KEY=
FIRECRAWL_INTAKE_MAX_PAGES=12

# KIE AI Gemini — copycat test page (https://kie.ai)
KIE_AI_API_KEY=
KIE_GEMINI_MODEL=gemini-3-5-flash

# DMCA automation — email delivery via Resend (https://resend.com)
RESEND_API_KEY=
DMCA_FROM_EMAIL="Moodna DMCA <dmca@yourdomain.com>"
DMCA_REPLY_TO_EMAIL=
# Set true to auto-submit after notice is prepared (still requires Approve in UI today)
DMCA_AUTO_SUBMIT=false

# Edge functions proxy to deployed API in production
MOODNA_API_URL=http://localhost:8787
